---
const { message = "⚡ เริ่มเล่นสล็อตวอเลทที่เร็วที่สุดในปี 2025 กับ PIGAUTO เว็บสล็อตอันดับ 1 ของวงการ!" } = Astro.props;
---

<div class="gxt1-container mx-auto max-w-[900px]" role="region" aria-label="ประกาศ">
  <div class="gxt1-label">🔥 ประกาศ :</div>

  <div class="gxt1-marquee">
    <div class="gxt1-track">
      <span class="gxt1-item">{message}</span>
      <span class="gxt1-item" aria-hidden="true">{message}</span>
    </div>
  </div>
</div>

<style>
  .gxt1-container {
    --speed: 20s;
    --radius: 18px;
    --bg1: #2b0000;
    --bg2: #800000;
    --border: #ff5560;

    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--bg2), var(--bg1));
    box-shadow:
      0 6px 12px rgba(255, 0, 51, 0.45),
      0 0 0 1px var(--border) inset;
    overflow: hidden;
    position: relative;
    color: #fff;
    font-size: 14px;
    line-height: 1;
  }

  .gxt1-label {
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(255, 60, 60, 0.16);
    border: 1px solid var(--border);
    font-weight: 800;
    box-shadow: 0 0 10px rgba(255, 85, 96, 0.4);
    flex-shrink: 0;
  }

  .gxt1-marquee {
    flex: 1;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 6%, #000 94%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, #000 6%, #000 94%, transparent 100%);
  }

  .gxt1-track {
    display: flex;
    gap: 32px;
    width: max-content;
    will-change: transform;
    animation: gxt1-scroll var(--speed) linear infinite;
  }

  .gxt1-item {
    white-space: nowrap;
  }

  @keyframes gxt1-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 16px));
    }
  }

  @media (max-width: 640px) {
    .gxt1-container {
      font-size: 11px;
      padding: 4px 8px;
    }
    .gxt1-label {
      padding: 3px 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gxt1-track {
      animation: none;
    }
  }
</style>
