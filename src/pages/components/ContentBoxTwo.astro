---
const { titleleft, titleright } = Astro.props;
---

<section
  class="mx-auto mb-3 w-full max-w-7xl rounded-[15px] border-2 border-[#570004] bg-[#050000]/90 p-8 text-center shadow-2xl"
  style="box-shadow: 0 0 14px rgba(235, 15, 26, 0.65), inset 0 0 12px rgba(255, 42, 53, 0.35)">
  <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-2">
    <article class="flex flex-col gap-4">
      {titleleft && <h2 class="mb-4 text-3xl font-bold">{titleleft}</h2>}
      <div class="text-white">
        <slot name="left" />
      </div>
    </article>

    <article class="flex flex-col gap-4">
      {titleright && <h2 class="mb-4 text-3xl font-bold">{titleright}</h2>}
      <div class="text-white">
        <slot name="right" />
      </div>
    </article>
  </div>
</section>
