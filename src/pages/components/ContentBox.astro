---
export interface Props {
  title?: string;
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
}
const { title, as: HeadingTag = "h1" } = Astro.props;
---

<section class="my-3 flex w-full justify-center px-4">
  <div
    class="w-full max-w-7xl rounded-[15px] border-2 border-[#570004] bg-[#050000]/90 p-8 text-center shadow-2xl"
    style="box-shadow: 0 0 14px rgba(235, 15, 26, 0.65), inset 0 0 12px rgba(255, 42, 53, 0.35)">
    {
      title && (
        <header class="mb-6">
          <HeadingTag class="text-3xl font-bold text-[#ffd700] drop-shadow-md">{title}</HeadingTag>
        </header>
      )
    }

    <div class="text-lg leading-relaxed text-white">
      <slot />
    </div>
  </div>
</section>
