---
import "swiper/css";

import { Picture } from "astro:assets";

import banner1 from "../../assets/pro1-2.webp";
import banner2 from "../../assets/pro2-2.webp";
import banner3 from "../../assets/pro4-1.webp";

const images = [banner1, banner2, banner3];
const displayImages = [...images, ...images, ...images];
---

<div class="mx-auto w-full max-w-[1301px] overflow-hidden px-4 py-5">
  <div class="swiper mySwiper">
    <div class="swiper-wrapper">
      {
        displayImages.map((img, index) => (
          <div class="swiper-slide">
            <Picture
              src={img}
              alt={`Banner ${index + 1}`}
              class="block w-full rounded-xl object-contain object-cover shadow-md"
              width={img.width}
              height={img.height}
              loading={index < 2 ? "eager" : "lazy"}
              fetchpriority={index === 0 ? "high" : "auto"}
              decoding="async"
              widths={[200, 400, 600]}
              sizes="(max-width: 768px) 50vw, 33vw"
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              quality={60}
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  let swiperLoaded = false;

  async function initSwiper() {
    // ถ้าเคยโหลดแล้ว ไม่ต้องโหลดซ้ำ
    if (swiperLoaded) return;
    swiperLoaded = true;

    try {
      const [{ default: Swiper }, { Autoplay }] = await Promise.all([import("swiper"), import("swiper/modules")]);

      new Swiper(".mySwiper", {
        modules: [Autoplay],
        loop: true,
        spaceBetween: 12,
        speed: 8000,
        autoplay: {
          delay: 0,
          disableOnInteraction: false,
        },
        slidesPerView: 2,
        breakpoints: {
          768: {
            slidesPerView: 3,
            spaceBetween: 16,
          },
        },
        init: false,
      }).init();
    } catch (e) {
      console.error("Swiper failed to load", e);
    }
  }

  function triggerSwiper() {
    if (window.requestIdleCallback) {
      requestIdleCallback(() => initSwiper(), { timeout: 2000 });
    } else {
      setTimeout(initSwiper, 2000);
    }
  }

  window.addEventListener("load", triggerSwiper);
  document.addEventListener("astro:page-load", triggerSwiper);

  ["mouseover", "keydown", "touchmove", "touchstart"].forEach((event) => {
    window.addEventListener(event, initSwiper, { once: true, passive: true });
  });
</script>
<style>
  .swiper-wrapper {
    transition-timing-function: linear !important;
  }

  .swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    overflow: hidden;
    gap: 12px;
  }

  .swiper:not(.swiper-initialized) .swiper-slide {
    flex: 0 0 calc((100% - 12px) / 2);
    width: calc((100% - 12px) / 2);
  }

  @media (min-width: 768px) {
    .swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 16px;
    }
    .swiper:not(.swiper-initialized) .swiper-slide {
      flex: 0 0 calc((100% - 32px) / 3);
      width: calc((100% - 32px) / 3);
    }
  }
</style>
