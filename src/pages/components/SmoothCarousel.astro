---
import "swiper/css";

import { Image } from "astro:assets";

import banner1 from "../../assets/pro2-2.webp";
import banner2 from "../../assets/pro1-2.webp";
import banner3 from "../../assets/pro4-1.webp";

const images = [banner1, banner2, banner3];
const displayImages = [...images, ...images, ...images];
---

<div class="mx-auto w-full max-w-[1101px] overflow-hidden px-4 py-5">
  <div class="swiper mySwiper">
    <div class="swiper-wrapper">
      {
        displayImages.map((img, index) => (
          <div class="swiper-slide">
            <Image
              src={img}
              alt={`Banner ${index + 1}`}
              class="block aspect-square w-full rounded-xl object-cover shadow-md"
              width={img.width}
              height={img.height}
              loading={index < 2 ? "eager" : "lazy"}
              fetchpriority={index === 0 ? "high" : "auto"}
              decoding="async"
              widths={[200, 400, 600]}
              sizes="(max-width: 768px) 50vw, 33vw"
              format="avif"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  let swiperLoaded = false;

  async function initSwiper() {
    // ถ้าเคยโหลดแล้ว ไม่ต้องโหลดซ้ำ
    if (swiperLoaded) return;
    swiperLoaded = true;

    try {
      // โหลด Swiper และ Modules แบบ Dynamic
      const [{ default: Swiper }, { Autoplay }] = await Promise.all([import("swiper"), import("swiper/modules")]);

      new Swiper(".mySwiper", {
        modules: [Autoplay],
        loop: true,
        spaceBetween: 12,
        speed: 8000,
        autoplay: {
          delay: 0,
          disableOnInteraction: false,
        },
        slidesPerView: 2,
        breakpoints: {
          768: {
            slidesPerView: 3,
            spaceBetween: 16,
          },
        },
        init: false,
      }).init();
    } catch (e) {
      console.error("Swiper failed to load", e);
    }
  }

  // 🌟 ฟังก์ชันอัจฉริยะ: เลือกโหลดตอนที่เบราว์เซอร์ว่าง (Idle) หรือคนขยับหน้าจอ
  function triggerSwiper() {
    if (window.requestIdleCallback) {
      // โหลดตอนเบราว์เซอร์ว่างจริงๆ (ดีต่อคะแนน Performance)
      requestIdleCallback(() => initSwiper(), { timeout: 2000 });
    } else {
      // ถ้าเบราว์เซอร์ไม่รองรับ ให้รอ 2 วินาทีแล้วโหลด
      setTimeout(initSwiper, 2000);
    }
  }

  // รองรับทั้งการเข้าเว็บปกติ และ Astro View Transitions
  window.addEventListener("load", triggerSwiper);
  document.addEventListener("astro:page-load", triggerSwiper);

  // สำรอง: ถ้าคนเลื่อนจอก่อนที่มันจะว่าง ให้โหลดทันทีเลย
  ["mouseover", "keydown", "touchmove", "touchstart"].forEach((event) => {
    window.addEventListener(event, initSwiper, { once: true, passive: true });
  });
</script>
<style>
  /* 1. Animation ตั้งต้นของ Swiper */
  .swiper-wrapper {
    transition-timing-function: linear !important;
  }

  /* 🌟 2. โค้ดพระเอก! จัดหน้าตาตอนที่ Swiper JS ยังโหลดไม่เสร็จ 🌟 */
  .swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    overflow: hidden;
    gap: 12px; /* ระยะห่างสำหรับมือถือ */
  }

  /* บังคับให้มือถือโชว์ 2 รูป (เหมือน slidesPerView: 2) */
  .swiper:not(.swiper-initialized) .swiper-slide {
    flex: 0 0 calc((100% - 12px) / 2);
    width: calc((100% - 12px) / 2);
  }

  /* บังคับให้ Desktop โชว์ 3 รูป (เหมือน slidesPerView: 3) */
  @media (min-width: 768px) {
    .swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 16px; /* ระยะห่างสำหรับ Desktop */
    }
    .swiper:not(.swiper-initialized) .swiper-slide {
      flex: 0 0 calc((100% - 32px) / 3); /* ลบด้วย (16px * 2 ช่องว่าง) */
      width: calc((100% - 32px) / 3);
    }
  }
</style>
