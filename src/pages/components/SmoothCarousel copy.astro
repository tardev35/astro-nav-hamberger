---
// 1. Import CSS ของ Swiper ไว้ตรงนี้เลย ถูกต้องแล้วครับ
import "swiper/css";

import { Image } from "astro:assets";

import banner1 from "../../assets/pro2-2.webp";
import banner2 from "../../assets/pro1-2.webp";
import banner3 from "../../assets/pro4-1.webp";

const images = [banner1, banner2, banner3];
const displayImages = [...images, ...images, ...images];
---

<div class="mx-auto w-full max-w-[1100px] overflow-hidden px-4 py-5">
  <div class="swiper mySwiper">
    <div class="swiper-wrapper">
      {
        displayImages.map((img, index) => (
          <div class="swiper-slide">
            <Image src={img} alt={`Banner ${index + 1}`} class="block aspect-square w-full rounded-xl object-cover shadow-md" loading={index < 2 ? "eager" : "lazy"} decoding="async" />
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  // 2. Import Swiper Modules แบบปกติ Astro จะทำการ Bundle ให้เองอย่างมีประสิทธิภาพ
  import Swiper from "swiper";
  import { Autoplay } from "swiper/modules";

  function initSwiper() {
    new Swiper(".mySwiper", {
      modules: [Autoplay],
      loop: true,
      spaceBetween: 12,
      speed: 3000,
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
      },
      slidesPerView: 2,
      breakpoints: {
        768: {
          slidesPerView: 3,
          spaceBetween: 16,
        },
      },
    });
  }

  // 3. รัน Swiper ทันทีที่ DOM พร้อม (รองรับกรณีใช้ Astro View Transitions ด้วย)
  document.addEventListener("astro:page-load", initSwiper);

  // รันครั้งแรกสำหรับหน้าที่โหลดแบบปกติ
  if (!document.documentElement.hasAttribute("data-astro-transition-persist")) {
    initSwiper();
  }
</script>

<style>
  /* 4. ลบ .swiper { display: flex; } ทิ้งไป เหลือแค่ตัวนี้เพื่อให้ไหลแบบไม่สะดุด */
  .swiper-wrapper {
    transition-timing-function: linear !important;
  }
</style>
