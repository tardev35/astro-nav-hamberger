---
import MainLayout from "../layouts/MainLayout.astro";
import ContentBox from "./components/ContentBox.astro";
import Navfoot from "./components/Navfoot.astro";
import Footer from "./components/Footer.astro";
import Announcement from "./components/Announcement.astro";

import { Picture } from "astro:assets";
import image1 from "../assets/gamedemo7.webp";
import image2 from "../assets/gamedemo8.webp";
import image3 from "../assets/gamedemo9.webp";
import image4 from "../assets/gamedemo10.webp";
import image5 from "../assets/gamedemo11.webp";
import image6 from "../assets/gamedemo12.webp";
import image7 from "../assets/gamedemo13.webp";
import image8 from "../assets/gamedemo14.webp";
import image9 from "../assets/gamedemo15.webp";
import image10 from "../assets/gamedemo16.webp";
import image11 from "../assets/gamedemo17.webp";
import image12 from "../assets/gamedemo18.webp";

const demoGames = [
  { id: 1, src: image1, alt: "เกมสล็อตที่ 1", link: "/signup" },
  { id: 2, src: image2, alt: "เกมสล็อตที่ 2", link: "/signup" },
  { id: 3, src: image3, alt: "เกมสล็อตที่ 3", link: "/signup" },
  { id: 4, src: image4, alt: "เกมสล็อตที่ 4", link: "/signup" },
  { id: 5, src: image5, alt: "เกมสล็อตที่ 5", link: "/signup" },
  { id: 6, src: image6, alt: "เกมสล็อตที่ 6", link: "/signup" },
  { id: 7, src: image7, alt: "เกมสล็อตที่ 7", link: "/signup" },
  { id: 8, src: image8, alt: "เกมสล็อตที่ 8", link: "/signup" },
  { id: 9, src: image9, alt: "เกมสล็อตที่ 9", link: "/signup" },
  { id: 10, src: image10, alt: "เกมสล็อตที่ 10", link: "/signup" },
  { id: 11, src: image11, alt: "เกมสล็อตที่ 11", link: "/signup" },
  { id: 12, src: image12, alt: "เกมสล็อตที่ 12", link: "/signup" },
];
---

<MainLayout title="ทดลองเล่นสล็อต" description="ไม่ต้องเติมเครดิต ลองเล่นสล็อตฟรีได้ทุกค่าย">
  <Announcement />

  <ContentBox title="ทดลองเล่นสล็อตอัตราจ่ายโหด ไม่ต้องเติมเครดิต">
    <p class="mb-8 text-gray-200">ศูนย์รวมเกมสล็อตทดลองเล่นฟรี อัปเดตเกมใหม่ล่าสุดก่อนใคร ไม่ต้องฝาก ไม่ต้องแชร์ เข้าเล่นได้ทันที!</p>

    <div class="mb-5 grid grid-cols-2 gap-5 sm:grid-cols-2 md:grid-cols-4">
      {
        demoGames.map((game) => (
          <div class="group relative flex flex-col gap-4 overflow-hidden rounded-xl">
            <Picture
              src={game.src}
              alt={game.alt}
              loading="lazy"
              fetchpriority="low"
              widths={[200, 400, 600]}
              sizes="(max-width: 768px) 100vw, 25vw"
              class="mx-auto h-auto w-full max-w-[400px] object-cover shadow-xl transition-transform duration-300 group-hover:scale-105"
              decoding="async"
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              quality={60}
            />
            <a
              href={game.link}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`ทดลองเล่น ${game.alt}`}
              class="absolute inset-0 flex items-center justify-center bg-black/50 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <span class="rounded-full bg-gradient-to-r from-yellow-400 to-yellow-600 px-6 py-2 font-bold text-black shadow-lg transition-transform hover:scale-110">เล่นเลย</span>
            </a>
          </div>
        ))
      }
    </div>
  </ContentBox>

  <Footer />
  <Navfoot />
</MainLayout>
