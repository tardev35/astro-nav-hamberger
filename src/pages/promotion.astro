---
import MainLayout from "../layouts/MainLayout.astro";
import ContentBox from "./components/ContentBox.astro";
import Navfoot from "./components/Navfoot.astro";
import Footer from "./components/Footer.astro";
import Announcement from "./components/Announcement.astro";

import { Picture } from "astro:assets";
import image1 from "../assets/pro1-2.webp";
import image2 from "../assets/pro2-2.webp";
import image3 from "../assets/pro4-1.webp";
---

<MainLayout title="โปรโมชั่น PIGAUTO99" , description="รับโปรโมชั่นจุใจจาก PIGAUTO99">
  <Announcement />
  <ContentBox>
    <h1 class="mb-7 text-3xl text-amber-400">รับโปรโมชั่นจุใจจาก PIGAUTOPG</h1>
    <p class="mb-8 text-gray-200">
      รับโปรโมชั่นจุใจจาก PIGAUTOPG รับโปรโมชั่นจุใจจาก PIGAUTOPG รับโปรโมชั่นจุใจจาก PIGAUTOPG รับโปรโมชั่นจุใจจาก PIGAUTOPG รับโปรโมชั่นจุใจจาก PIGAUTOPG รับโปรโมชั่นจุใจจาก PIGAUTOPG
    </p>
    <div class="mb-5 grid grid-cols-1 gap-5 md:grid-cols-3">
      <div class="flex flex-col gap-4">
        <Picture
          src={image1}
          alt="Pigauto"
          loading="lazy"
          fetchpriority="low"
          widths={[200, 400, 600]}
          sizes="(max-width: 768px) 100vw, 33vw"
          class="mx-auto h-auto w-full max-w-[400px] object-contain shadow-xl"
          decoding="async"
          formats={["avif", "webp"]}
          fallbackFormat="webp"
          quality={60}
        />
      </div>

      <div class="flex flex-col gap-4">
        <Picture
          src={image2}
          alt="Pigauto"
          loading="lazy"
          fetchpriority="low"
          widths={[200, 400, 600]}
          sizes="(max-width: 768px) 100vw, 33vw"
          class="mx-auto h-auto w-full max-w-[400px] object-contain shadow-xl"
          decoding="async"
          formats={["avif", "webp"]}
          fallbackFormat="webp"
          quality={80}
        />
      </div>

      <div class="flex flex-col gap-4">
        <Picture
          src={image3}
          alt="Pigauto"
          loading="lazy"
          fetchpriority="low"
          widths={[200, 400, 600]}
          sizes="(max-width: 768px) 100vw, 33vw"
          class="mx-auto h-auto w-full max-w-[400px] object-contain shadow-xl"
          decoding="async"
          formats={["avif", "webp"]}
          fallbackFormat="webp"
          quality={80}
        />
      </div>

      <div class="flex flex-col gap-4">
        <Picture
          src={image3}
          alt="Pigauto"
          loading="lazy"
          fetchpriority="low"
          widths={[200, 400, 600]}
          sizes="(max-width: 768px) 100vw, 33vw"
          class="mx-auto h-auto w-full max-w-[400px] object-contain shadow-xl"
          decoding="async"
          formats={["avif", "webp"]}
          fallbackFormat="webp"
          quality={80}
        />
      </div>
    </div>
  </ContentBox>
</MainLayout>
<Footer />
<Navfoot />
